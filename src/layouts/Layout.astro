---
import { Icon } from "astro-icon/components";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Historia e los mundiales</title>
	</head>

	<body>
		<header class="flex justify-between items-center py-4 px-10 bg-zinc-200 text-black">
			<p class="text-blue-950 font-black text-3xl">MUNDIAL HISTORICO</p>
			<div class="flex gap-4 font-bold ">
				<a href="/">INICIO</a>
				<a href="/calendario">CALENDARIO</a>
				<a href="/equipos">EQUIPOS</a>
			</div>
			<div class="flex gap-4">
				<button class="font-bold text-blue-700">
					<Icon name="notificacion" size={32}></Icon>
				</button>
				<button class="font-bold bg-blue-950 text-white px-3 rounded-2xl">Registrarme</button>
			</div>
		</header>

		<slot />
	</body>
</html>
