---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section class="px-10 py-10">
        <div class="py-5">
            <div class="bg-blue-950 rounded-2xl px-10 py-25 text-white">
                <p class="font-bold bg-amber-500 rounded-2xl inline-flex px-4">World Cup 2024</p>
                <p class="font-black text-7xl py-4">LA ÉLITE GLOBAL</p>
                <p class="font-bold py-10 text-xl text-gray-400">
                    Explora las 32 naciones que compiten por la gloria <br
                    />máxima del fútbol. Análisis profundo de plantillas, <br /> estadísticas
                    de jugadores y formas tácticas.
                </p>
            </div>
        </div>
    </section>
    <section class="px-10 py-20">
        <div class="bg-gray-50 p-10 flex flex-col gap-8 font-sans">
  
  <div class="flex justify-between items-center">
    <div class="flex flex-col gap-1">
      <h2 class="text-3xl font-black text-[#002d5a] tracking-tight">Naciones Clasificadas</h2>
      <div class="flex items-center gap-3">
        <div class="bg-green-600 h-[3px] w-10"></div>
        <span class="text-gray-500 text-xs font-bold uppercase tracking-widest">Fase de Grupos</span>
      </div>
    </div>
    
    <div class="flex gap-3">
      <button class="bg-[#e2e8f0] text-[#002d5a] px-5 py-2 rounded-full text-xs font-bold">Todos los Grupos</button>
      <button class="bg-[#00642d] text-white px-5 py-2 rounded-full text-xs font-bold flex items-center gap-2">
        Filtrar por Ranking
      </button>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    
    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
      <div class="h-24 p-6 bg-gradient-to-br from-blue-50 to-white flex justify-between items-start">
        <div class="w-12 h-8 bg-gray-200 rounded-sm overflow-hidden">
          <img src="/path/to/arg.png" class="w-full h-full object-cover" />
        </div>
        <div class="text-right">
          <p class="text-[8px] font-black text-gray-400 uppercase tracking-tighter">Ranking FIFA</p>
          <p class="text-2xl font-black text-[#002d5a] italic">#1</p>
        </div>
      </div>
      <div class="p-6 flex flex-col gap-6">
        <h3 class="text-xl font-black text-[#002d5a]">Argentina</h3>
        <div class="flex flex-col gap-2">
          <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">Forma Reciente</p>
          <div class="flex gap-1.5">
            {['W','W','W','D','W'].map(f => (
              <span class={`w-5 h-5 ${f === 'W' ? 'bg-green-600' : 'bg-yellow-500'} text-white text-[8px] font-bold rounded-full flex items-center justify-center`}>{f}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
      <div class="h-24 p-6 bg-gradient-to-br from-indigo-50 to-white flex justify-between items-start">
        <div class="w-12 h-8 bg-gray-200 rounded-sm overflow-hidden">
          <img src="/path/to/fra.png" class="w-full h-full object-cover" />
        </div>
        <div class="text-right">
          <p class="text-[8px] font-black text-gray-400 uppercase tracking-tighter">Ranking FIFA</p>
          <p class="text-2xl font-black text-[#002d5a] italic">#2</p>
        </div>
      </div>
      <div class="p-6 flex flex-col gap-6">
        <h3 class="text-xl font-black text-[#002d5a]">France</h3>
        <div class="flex flex-col gap-2">
          <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">Forma Reciente</p>
          <div class="flex gap-1.5">
            {['W','W','L','W','W'].map(f => (
              <span class={`w-5 h-5 ${f === 'W' ? 'bg-green-600' : 'bg-red-600'} text-white text-[8px] font-bold rounded-full flex items-center justify-center`}>{f}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
      <div class="h-24 p-6 bg-gradient-to-br from-yellow-50 to-white flex justify-between items-start">
        <div class="w-12 h-8 bg-gray-200 rounded-sm overflow-hidden">
          <img src="/path/to/bra.png" class="w-full h-full object-cover" />
        </div>
        <div class="text-right">
          <p class="text-[8px] font-black text-gray-400 uppercase tracking-tighter">Ranking FIFA</p>
          <p class="text-2xl font-black text-[#002d5a] italic">#5</p>
        </div>
      </div>
      <div class="p-6 flex flex-col gap-6">
        <h3 class="text-xl font-black text-[#002d5a]">Brazil</h3>
        <div class="flex flex-col gap-2">
          <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">Forma Reciente</p>
          <div class="flex gap-1.5">
            {['W','D','W','W','D'].map(f => (
              <span class={`w-5 h-5 ${f === 'W' ? 'bg-green-600' : 'bg-yellow-500'} text-white text-[8px] font-bold rounded-full flex items-center justify-center`}>{f}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
      <div class="h-24 p-6 bg-gradient-to-br from-red-50 to-white flex justify-between items-start">
        <div class="w-12 h-8 bg-gray-200 rounded-sm overflow-hidden">
          <img src="/path/to/eng.png" class="w-full h-full object-cover" />
        </div>
        <div class="text-right">
          <p class="text-[8px] font-black text-gray-400 uppercase tracking-tighter">Ranking FIFA</p>
          <p class="text-2xl font-black text-[#002d5a] italic">#4</p>
        </div>
      </div>
      <div class="p-6 flex flex-col gap-6">
        <h3 class="text-xl font-black text-[#002d5a]">England</h3>
        <div class="flex flex-col gap-2">
          <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">Forma Reciente</p>
          <div class="flex gap-1.5">
            {['W','W','W','W','W'].map(f => (
              <span class="w-5 h-5 bg-green-600 text-white text-[8px] font-bold rounded-full flex items-center justify-center">{f}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
      <div class="h-24 p-6 bg-gradient-to-br from-red-50 to-white flex justify-between items-start">
        <div class="w-12 h-8 bg-gray-200 rounded-sm overflow-hidden">
          <img src="/path/to/jpn.png" class="w-full h-full object-cover" />
        </div>
        <div class="text-right">
          <p class="text-[8px] font-black text-gray-400 uppercase tracking-tighter">Ranking FIFA</p>
          <p class="text-2xl font-black text-[#002d5a] italic">#18</p>
        </div>
      </div>
      <div class="p-6 flex flex-col gap-6">
        <h3 class="text-xl font-black text-[#002d5a]">Japan</h3>
        <div class="flex flex-col gap-2">
          <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">Forma Reciente</p>
          <div class="flex gap-1.5">
            {['W','W','W','W','D'].map(f => (
              <span class={`w-5 h-5 ${f === 'W' ? 'bg-green-600' : 'bg-yellow-500'} text-white text-[8px] font-bold rounded-full flex items-center justify-center`}>{f}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden flex flex-col">
      <div class="h-24 p-6 bg-gradient-to-br from-red-100 to-white flex justify-between items-start">
        <div class="w-12 h-8 bg-gray-200 rounded-sm overflow-hidden">
          <img src="/path/to/mar.png" class="w-full h-full object-cover" />
        </div>
        <div class="text-right">
          <p class="text-[8px] font-black text-gray-400 uppercase tracking-tighter">Ranking FIFA</p>
          <p class="text-2xl font-black text-[#002d5a] italic">#13</p>
        </div>
      </div>
      <div class="p-6 flex flex-col gap-6">
        <h3 class="text-xl font-black text-[#002d5a]">Morocco</h3>
        <div class="flex flex-col gap-2">
          <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest">Forma Reciente</p>
          <div class="flex gap-1.5">
            {['W','D','W','W','L'].map(f => (
              <span class={`w-5 h-5 ${f === 'W' ? 'bg-green-600' : f === 'D' ? 'bg-yellow-500' : 'bg-red-600'} text-white text-[8px] font-bold rounded-full flex items-center justify-center`}>{f}</span>
            ))}
          </div>
        </div>
        
      </div>
    </div>


  </div>
</div>
    </section>
    <section class="px-10 py-30">
        <div class="bg-blue-100 rounded-2xl ">
            <div class="flex gap-10 px-10 py-20 rounded-2xl">
                <div class="bg-white px-10 rounded-2xl py-10">
                    <div class="flex justify-center gap-8 py-5">
                        <div>
                            <p class="font-bold text-xl text-blue-950">NACIONES <br> CLASIFICADAS</p>
                            <p class="font-bold text-green-500">CAMPEONES DEFENSORES</p>
                        </div>
                    </div>
                    <div class="py-5">
                        <p class="text-gray-400 uppercase font-bold text-xs">Entrenador</p>
                        <p class="text-blue-950 font-bold text-xl">Lionel escaloni</p>
                    </div>
                    <div class="py-5">
                        <p class="uppercase text-xs text-gray-400 font-bold">Títulos Mundiales</p>
                        icon icon icon
                    </div>
                    <div class="bg-blue-100 rounded-2xl py-5 px-5">
                        <p class="text-blue-950 font-bold">Objetivo del torneo</p>
                        <p>
                            "Mantener el estándar de excelencia y <br> honrar la camiseta
                            cada minuto en el <br> campo."
                        </p>
                    </div>
                </div>
                <div class="bg-blue-950 rounded-2xl px-20 ">
                    <div class="py-10">
                        <p class="text-white font-bold text-xl">Edad Media de la Plantilla</p>
                    </div>
                    <div>
                        <p class="text-white font-bold text-7xl">27.4</p>
                        <p class="text-gray-400 font-bold">Núcleo de gran experiencia</p>
                    </div>
                </div>
                <div class="">
                    <div class="flex gap-5">
                        <div class="bg-green-500 rounded-2xl">
                            <p class="py-5 px-10 font-bold text-gray-200">VALOR TOTAL</p>
                            <p class="px-10 text-white font-bold text-4xl">€850M</p>
                        </div>
                        <div class="bg-yellow-800 rounded-2xl">
                            <p class="py-5 px-10 text-amber-100">MÁXIMO <br> GOLEADOR</p>
                            <p class="py-2 px-10 text-4xl font-bold text-white">L. Messi</p>
                            <p class="px-10 text-white">106 Goles</p>
                        </div>
                    </div>
                    <div class="py-5">
                        <div class="bg-white rounded-2xl">
                            <p class="text-gray-400 py-4 font-bold">ESQUEMA TÁCTICO</p>
                            <p class="font-black text-2xl text-blue-950">4 - 3 - 3</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
