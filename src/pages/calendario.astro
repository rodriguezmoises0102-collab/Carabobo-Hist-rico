                    </div>
                    <div>
                        <div>
                            <p>P</p>
                        </div>
                        <div>
                            <p>GD</p>
                        </div>
                        <div>
                            <p>PUNTOS</p>
                        </div>
                    </div>
                    <div>
                        <div>
                            <div>
                                icon "lo pongo en clase"
                                <p>FRANCIA</p>
                                <div>
                                    <p>2</p>
                                </div>
                                <div>
                                    <p>+4</p>
                                </div>
                                <div>
                                    <p>6</p>
                                </div>
                            </div>
                        </div>
                        <div>
                            ICON "LO PONGO EN CLASE"
                            <p>BRAZIL</p>
                            <div>
                                <p>2</p>
                            </div>
                            <div>
                                <p>+2</p>
                            </div>
