                            icon "lo pongo en clase"
                            <p>GHANA</p>
                            <div>
                                <p>2</p>
                            </div>
                            <div>
                                <p>-5</p>
                            </div>
                            <div>
                                <p>5</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
