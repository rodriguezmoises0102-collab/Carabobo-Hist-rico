                                    Icon
                                </div>
                                <p class="font-bold text-blue-950">ESPAÑA</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div>
                    <p class="font-bold text-2xl text-gray-200">MAÑANA . 19 DE JUNIO</p>
                </div>

                <div>
                    <div>
                        <div>
                            <div>
                                Icon 
                                <p class="font-bold text-blue-950 text-xs">ARGENTINA</p>
                            </div>
                            <div>
                                <p class="text-xs text-gray-400">VS</p>
                            </div>
                            <div>
                                icon "lo pongo en clase"
                                <p class="font-bold text-blue-950 text-xs">CROACIA</p>
                            </div>
                        </div>
                        <div>
                            <p class="font-bold text-xs text-orange-300">Grupo C</p>
