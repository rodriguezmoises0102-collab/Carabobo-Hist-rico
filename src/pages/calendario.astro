---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section class="p-12 bg-blue-950">
        <div class="flex items-end gap-24">
            <div>
                <p class="text-white">Mundial Mexico-USA</p>
                <p class="text-5xl font-bold text-white">FINALES DEL MUNDIAL</p>
                <p class="font-bold tex-xs text-gray-400">
                    Sé testigo de la cima del fútbol mundial. sigue cada
                    partido,analiza la clasificación de los grupos y sigue el
                    camino hacia el trofeo
                </p>
            </div>
            <div>
                <p class="text-white font-bold">14 Días restantes</p>
            </div>
        </div>
    </section>



    <section>
        <div class= "flex flex-1" >
            <div >
                <div class="py-5" >
                    <p class="font-bold text-blue-950 flex-1 text-2xl">Hoy . 18 de Junio</p>
                </div>

                <div>
                    <div>
                        <div>
                            <p class="font-bold text-blue-950">Grupo A</p>
                        </div>
                        <div>
