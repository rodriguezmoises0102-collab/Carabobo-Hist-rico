                                    Icon
                                </div>
                                <p class="font-bold text-blue-950">Brazil</p>
                            </div>
                        </div>
                    </div>
                    <div>
                        <div>
                            <p class="font-bold text-blue-950 text-xs">Grupo B</p>
                        </div>
                        <div>
                            <div>
                                <div class="w-12 h-12 bg-blue-950 rounded-full">
                                    Icon
                                </div>
                                <p class="font-bold text-blue-950">Japon</p>
                            </div>
                            <div>
                                <p class="text-xl text-gray-400">VS</p>
                                <p class="font-bold text-yellow-500 text-xs">DOHA ARENA</p>
                            </div>
