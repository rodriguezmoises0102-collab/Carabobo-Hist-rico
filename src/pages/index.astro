---
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout>
  <section
    class="relative overflow-hidden bg-blue-950/85 text-white flex-items-center py-50"
  >
    <img
      class="absolute -z-10 w-full -top-2/3 left-0 object-cover"
      src="/estadio.png"
      alt=""
    />
    <div class="flex flex-1">
      <div class="flex flex-col items-start px-12 py-12">
        <div
          class="inline-flex items-center gap-2 bg-secondary/20 backdrop-blur-md px-4 py-1.5 rounded-full border border-secondary/30"
        >
          <p
            class="text-secondary-fixed text-xs font-bold uppercase tracking-widest font-label"
          >
            Road to the Final 2024
          </p>
        </div>
        <div>
          <p class="text-white text-7xl font-bold">SIENTE LA</p>
          <p class="text-yellow-300 text-7xl font-bold">ENERGÍA</p>
          <p class="text-yellow-300 text-7xl font-bold">SINÉTICA</p>
          <p>
            Vive cada gol, cada emoción y cada momento de gloria del torneo más
            grande del mundo.
          </p>
        </div>
      </div>
      <div
        class="borde border-white/10 bg-blue-950/90 bg-sunface-container-lowest/10 justify-end py-20 px-10"
      >
        <div>
          <div class="flex gap-50">
            <p class="text-yellow-300 font-bold">PRÓXIMO GRAN PARTIDO</p>
            <p class="text-xs font-bold text-gray-500">
              Fase de Grupos • 14 de junio
            </p>
          </div>
        </div>
        <div class="flex items-center gap-30 py-8">
          <div>
            <Icon name="brazil" size={50} />
            <p class="font-bold py-5">BRAZIL</p>
          </div>
          <div class="flex-1 text-center">
            <p class="text-gray-500 font-bold text-3xl">VS</p>
          </div>
          <div>
            <Icon name="francia" size={50} />
            <p class="font-bold py-5">FRANCIA</p>
          </div>
        </div>
        <div class="flex gap-10">
          <div class="inline-flex bg-gray-500/50 py-5 px-4">
            <p class="font-bold text-2xl">04</p>
            <p class="text-gray-500 text-xs font-bold">DIAS</p>
          </div>
          <div class="inline-flex bg-gray-500/50 py-5 px-4">
            <p class="font-bold text-2xl">12</p>
            <p class="text-gray-500 text-xs font-bold">HORAS</p>
          </div>
          <div class="inline-flex bg-gray-500/50 py-5 px-4">
            <p class="font-bold text-2xl">45</p>
            <p class="font-bold text-gray-500 text-xs">MINUTOS</p>
          </div>
          <div class="inline-flex bg-gray-500/50 py-5 px-4">
            <p class="font-bold text-2xl">22</p>
            <p class="font-bold text-gray-500 text-xs">SEGUNDOS</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="">
 <div class="bg-gray-50 p-10 flex flex-col gap-10 font-sans">

  <div class="flex justify-between items-end">
    <div class="flex flex-col gap-3">
      <div class="text-[40px] font-black text-blue-950 uppercase leading-[0.9] tracking-tighter">
        Titulares del<br>Torneo
      </div>
      <div class="bg-green-600 h-[5px] w-16"></div>
    </div>
    <div class="text-blue-950 font-bold text-[11px] flex items-center gap-2 mb-2 uppercase">
      Ver todas las noticias <div class="text-lg">→</div>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row gap-6">
    
    <div class="flex-[1.8] relative h-[520px] rounded-[2.5rem] overflow-hidden bg-slate-200">
      <img 
        src="/index1.png" 
        class="absolute inset-0 w-full h-full object-cover" 
      />
      
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>

      <div class="absolute bottom-0 left-0 p-12 flex flex-col gap-4 z-10">
        <div class="bg-yellow-600 text-blue-950 text-[10px] font-bold uppercase px-3 py-1 rounded w-fit">Exclusivo</div>
        <div class="text-5xl font-black text-white uppercase leading-[1.05] tracking-tight">
          Estrellas emergentes:<br>los desvalidos sacuden<br>el grupo c
        </div>
        <div class="text-gray-300 text-sm max-w-md leading-relaxed font-medium">
          Cómo las naciones más pequeñas están desafiando las probabilidades y reescribiendo el guión del torneo...
        </div>
      </div>
    </div>

    <div class="flex-1 flex flex-col gap-6">
      
      <div class="bg-white rounded-[2.5rem] overflow-hidden shadow-sm flex flex-col h-full border border-gray-100">
        <div class="h-60 overflow-hidden">
          <img 
            src="/index.png" 
            class="w-full h-full object-cover" 
          />
        </div>
        <div class="p-8 flex flex-col gap-3">
          <div class="text-green-700 text-[10px] font-bold uppercase tracking-widest">Equipamiento</div>
          <div class="text-xl font-black text-blue-950 uppercase leading-tight tracking-tight">
            Nuevo balón oficial con tecnología integrada presentado
          </div>
        </div>
      </div>

      <div class="bg-blue-50 rounded-[2rem] p-6 flex items-center gap-6">
        <div class="flex-1 flex flex-col gap-2">
          <div class="text-red-600 text-[10px] font-bold uppercase tracking-widest">Tácticas</div>
          <div class="text-sm font-black text-blue-950 uppercase leading-tight tracking-tight">
            Maestros de la defensa: los mejores porteros de 2024
          </div>
        </div>
        <div class="w-20 h-20 rounded-2xl overflow-hidden shrink-0">
          <img 
            src="/portero.png"  
            class="w-full h-full object-cover" 
          />
        </div>
      </div>

    </div>
  </div>
</div>
  </section>

  <section class="">
    <div class="bg-gray-50 p-12 flex flex-col gap-12 font-sans text-slate-900">

  <div class="flex flex-col gap-2">
    <div class="text-3xl font-black text-blue-950 uppercase leading-none tracking-tight">
      Resúmenes de<br>
      los partidos
    </div>
    <div class="text-sm text-gray-500 max-w-lg font-medium">
      Vuelve a ver los momentos más explosivos de la semana.
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    <div class="bg-white rounded-[2rem] shadow-sm overflow-hidden flex flex-col group border border-gray-100">
      
      <div class="relative h-64 overflow-hidden bg-slate-200">
        <img 
          src="/foto1.png"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" 
        />
        <div class="absolute inset-0 bg-black/10"></div>
      </div>

      <div class="p-8 flex flex-col gap-3">
        <div class="text-base font-extrabold text-blue-950 uppercase leading-snug tracking-tight">
          Brazil vs South Korea | Todos los goles y resumen extendido
        </div>
        <div class="text-gray-400 text-[11px] font-medium tracking-wide">
          Grupo A • 3.2M Vistas • hace 2h
        </div>
      </div>
    </div>

    <div class="bg-white rounded-[2rem] shadow-sm overflow-hidden flex flex-col group border border-gray-100">
      
      <div class="relative h-64 overflow-hidden bg-slate-200">
        <img 
          src="/foto2.png"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" 
        />
        <div class="absolute inset-0 bg-black/10"></div>
      </div>

      <div class="p-8 flex flex-col gap-3">
        <div class="text-base font-extrabold text-blue-950 uppercase leading-snug tracking-tight">
          Milagro de último minuto: Gol de la victoria en tiempo de descuento
        </div>
        <div class="text-gray-400 text-[11px] font-medium tracking-wide">
          Grupo B • 1.8M Vistas • hace 5h
        </div>
      </div>
    </div>

    <div class="bg-white rounded-[2rem] shadow-sm overflow-hidden flex flex-col group border border-gray-100">
      
      <div class="relative h-64 overflow-hidden bg-slate-200">
        <img 
          src="/foto3.png" 
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" 
        />
        <div class="absolute inset-0 bg-black/10"></div>
      </div>

      <div class="p-8 flex flex-col gap-3">
        <div class="text-base font-extrabold text-blue-950 uppercase leading-snug tracking-tight">
          Reacción de los fans: Ambiente en el Estadio Lusail esta noche
        </div>
        <div class="text-gray-400 text-[11px] font-medium tracking-wide">
          Cultura • 890K Vistas • hace 12h
        </div>
      </div>
    </div>

  </div>

</div>
  </section>
  <section>
    <div class="bg-gray-50 p-10 flex justify-center items-center font-sans">
  
  <div class="bg-[#003057] w-full max-w-6xl rounded-[3rem] p-16 flex flex-col items-center text-center gap-8 relative overflow-hidden shadow-2xl">
    
    <div class="flex flex-col gap-2 z-10">
      <h2 class="text-white text-6xl font-black uppercase tracking-tighter leading-none">
        No te pierdas la<br/>final
      </h2>
    </div>

    <p class="text-gray-300 text-lg max-w-2xl leading-relaxed z-10">
      Las entradas se agotan rápido para el clímax del torneo. Asegura tu asiento y sé testigo de la historia.
    </p>

    <div class="flex gap-4 mt-4 z-10">
      <button class="bg-[#007a2e] text-white font-bold px-10 py-4 rounded-full text-sm uppercase tracking-widest transition-all hover:scale-105 active:scale-95 shadow-[0_0_20px_rgba(0,122,46,0.6)]">
        Reserva tus asientos
      </button>
      
      <button class="border border-white/20 bg-white/5 text-white font-bold px-10 py-4 rounded-full text-sm uppercase tracking-widest transition-all hover:bg-white/10">
        Ver mapa de sedes
      </button>
    </div>

    <div class="w-full max-w-3xl h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mt-8"></div>

    <div class="grid grid-cols-3 gap-16 mt-4 z-10">
      <div class="flex flex-col items-center gap-1">
        <span class="text-[#ffcc00] text-3xl font-black">85%</span>
        <span class="text-white/40 text-[10px] font-bold uppercase tracking-widest text-center">Capacidad alcanzada</span>
      </div>
      
      <div class="flex flex-col items-center gap-1">
        <span class="text-white text-3xl font-black">12</span>
        <span class="text-white/40 text-[10px] font-bold uppercase tracking-widest text-center">Ciudades sede</span>
      </div>
      
      <div class="flex flex-col items-center gap-1">
        <span class="text-[#ffcc00] text-3xl font-black">32</span>
        <span class="text-white/40 text-[10px] font-bold uppercase tracking-widest text-center">Naciones participantes</span>
  
</Layout>

